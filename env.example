# 把這個檔案複製一份，改名成 .env，再填入你自己的資料
# 在 Render 上部署時，這些值不要寫進程式碼，而是填到 Render 的 Environment Variables 設定裡

# 後台網頁的登入密碼（自己設一個，登入管理頁面、新增客戶、發送通知時都要用到）
ADMIN_PASSWORD=請改成你自己的密碼

# LINE Developers Console -> Messaging API -> Channel access token
LINE_CHANNEL_ACCESS_TOKEN=你的LINE_Channel_Access_Token

# LINE Developers Console -> Messaging API -> Channel secret
LINE_CHANNEL_SECRET=你的LINE_Channel_Secret

# 伺服器埠號，Render 會自動設定，本機測試用 3000 即可
PORT=3000
